# --- TxLINE results feed (for refreshing data/fixtures with live results) ---
#
# The oracle, tests and demo run entirely off the committed evidence bundles
# in data/fixtures/, so credentials are only needed to *re-capture* results
# from the live feed (scripts/capture_results.py). Point this at the local
# creds file produced by the TxLINE auth flow; the secret never lives in the
# repo or in this file.
TXLINE_CREDS_FILE=/path/to/.txline_creds.json

# --- On-chain anchoring (optional — Solana devnet only) ---
#
# Anchoring is opt-in. The code never accepts a mnemonic/private key as an
# env *value*, only a *path* to a local wallet note file, so the secret never
# ends up in .env, shell history or a process environment dump. The file is a
# plain-text note containing a 12/24-word BIP-39 mnemonic on its own line
# (Phantom default derivation path m/44'/501'/0'/0').
#
# devnet ONLY. This wallet should never hold, and this code never sends,
# anything but devnet (worthless) SOL to pay its own memo-transaction fee.
SETTLEMENT_ORACLE_SOLANA_MNEMONIC_FILE=/path/to/your/devnet-wallet-note.txt

# Defaults to the public Solana devnet RPC; override for a private endpoint.
SETTLEMENT_ORACLE_SOLANA_RPC_URL=https://api.devnet.solana.com
